<Window x:Class="ProductsDishes.EditDishIngredientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductsDishes"
                Title="Edit ingredients"
        Width="650" Height="400"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10 4"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12 6"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="RowBackground" Value="#020617"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="LightDataGridStyle" TargetType="DataGrid">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>

        <Style x:Key="LightHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DataGrid Grid.Column="0"
                  ItemsSource="{Binding Ingredients}"
                  SelectedItem="{Binding SelectedIngredient}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Style="{StaticResource LightDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource LightHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="2*"/>
                <DataGridTextColumn Header="Quantity (g)" Binding="{Binding QuantityGrams}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1" Margin="12,0,0,0">
            <TextBlock Text="{Binding DishName}" FontSize="16" Margin="0,0,0,8"/>

            <TextBlock Text="Product"/>
            <ComboBox ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      DisplayMemberPath="Name"/>

            <TextBlock Text="Quantity (g)" Margin="0,6,0,0"/>
            <TextBox Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Add" Command="{Binding AddIngredientCommand}"/>
                <Button Content="Update" Command="{Binding UpdateIngredientCommand}"/>
                <Button Content="Delete" Command="{Binding DeleteIngredientCommand}"/>
            </StackPanel>

            <TextBlock Text="Search product by name" Margin="0,6,0,0"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Width="150"
                 Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,8,0"/>
                <Button Content="Search"
                    Command="{Binding SearchProductsCommand}"/>
                <Button Content="Clear"
                    Command="{Binding ClearProductsSearchCommand}"/>
            </StackPanel>

            <Button Content="Close" Margin="0,20,0,0" IsCancel="True" HorizontalAlignment="Right" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
